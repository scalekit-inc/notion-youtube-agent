# Scalekit credentials — get from your Scalekit dashboard
SCALEKIT_ENV_URL=https://your-env.scalekit.cloud
SCALEKIT_CLIENT_ID=prd_skc_xxxxx
SCALEKIT_CLIENT_SECRET=your_secret_here

# LLM — defaults to https://llm.scalekit.cloud (LiteLLM proxy)
LLM_API_KEY=your_api_key_here
# LLM_BASE_URL=https://llm.scalekit.cloud
# LLM_MODEL=claude-sonnet-4-6
